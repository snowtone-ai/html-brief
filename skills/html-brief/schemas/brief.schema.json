{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://html-brief.dev/schemas/brief.schema.json",
  "title": "html-brief common envelope",
  "description": "Common envelope shared by every html-brief artifact export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "archetype",
    "createdAt",
    "userIntent",
    "state",
    "initialState"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Export protocol version.",
      "const": "1.0"
    },
    "archetype": {
      "type": "string",
      "description": "Primary html-brief archetype.",
      "enum": [
        "plan",
        "compare",
        "review",
        "report",
        "editor"
      ]
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 date-time when the brief was generated.",
      "format": "date-time"
    },
    "updatedAt": {
      "type": [
        "string",
        "null"
      ],
      "description": "ISO 8601 date-time when the brief state was updated, or null if never updated.",
      "format": "date-time"
    },
    "skill": {
      "type": "object",
      "description": "Skill metadata for the export.",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Skill name.",
          "const": "html-brief"
        },
        "version": {
          "type": "string",
          "description": "Skill version string.",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        }
      }
    },
    "userIntent": {
      "type": "string",
      "description": "Original or summarized user request that produced the brief.",
      "minLength": 1
    },
    "state": {
      "type": "object",
      "description": "Archetype-specific current state. Validate with the matching archetype schema."
    },
    "initialState": {
      "type": [
        "object",
        "null"
      ],
      "description": "Initial state before user edits. Null for static artifacts."
    }
  },
  "$defs": {
    "idString": {
      "type": "string",
      "description": "Stable identifier for an item.",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "nonEmptyString": {
      "type": "string",
      "description": "Human-readable non-empty text.",
      "minLength": 1
    },
    "markdownString": {
      "type": "string",
      "description": "Markdown-compatible text content.",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "description": "Confidence level for a claim or recommendation.",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "status": {
      "type": "string",
      "description": "Lifecycle status for a brief or item.",
      "enum": [
        "draft",
        "proposed",
        "in_review",
        "approved",
        "blocked",
        "done"
      ]
    },
    "severity": {
      "type": "string",
      "description": "Severity level for a risk, finding, or warning.",
      "enum": [
        "blocker",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "evidenceType": {
      "type": "string",
      "description": "Type of support behind a claim.",
      "enum": [
        "source-backed",
        "user-provided",
        "code-derived",
        "inferred",
        "assumption",
        "uncertain"
      ]
    }
  }
}
