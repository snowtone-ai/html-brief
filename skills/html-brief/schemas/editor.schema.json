{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://html-brief.dev/schemas/editor.schema.json",
  "title": "html-brief Editor schema",
  "description": "Schema for an Editor archetype export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "archetype",
    "createdAt",
    "userIntent",
    "state",
    "initialState"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Export protocol version.",
      "const": "1.0"
    },
    "archetype": {
      "type": "string",
      "description": "Archetype identifier.",
      "const": "editor"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 generation timestamp.",
      "format": "date-time"
    },
    "updatedAt": {
      "type": [
        "string",
        "null"
      ],
      "description": "ISO 8601 update timestamp or null.",
      "format": "date-time"
    },
    "userIntent": {
      "type": "string",
      "description": "Original or summarized user request.",
      "minLength": 1
    },
    "initialState": {
      "type": "object",
      "description": "Initial editor state before user edits."
    },
    "state": {
      "type": "object",
      "description": "Current editor state.",
      "additionalProperties": false,
      "required": [
        "title",
        "editorType",
        "items",
        "changedKeys",
        "validation"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Editor title.",
          "minLength": 1
        },
        "editorType": {
          "type": "string",
          "description": "Type of editor UI.",
          "enum": [
            "form",
            "table",
            "kanban",
            "split-pane",
            "picker",
            "feature-flags",
            "prompt-tuner",
            "other"
          ]
        },
        "items": {
          "type": "array",
          "description": "Editable items.",
          "minItems": 1,
          "items": {
            "type": "object",
            "description": "Editable item.",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "value"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Item ID.",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "description": "Human label.",
                "minLength": 1
              },
              "group": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Group label or null."
              },
              "value": {
                "description": "Current value for the item.",
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "array"
                  },
                  {
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "initialValue": {
                "description": "Initial value for comparison.",
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "array"
                  },
                  {
                    "type": "object"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "dependsOn": {
                "type": "array",
                "description": "IDs this item depends on.",
                "items": {
                  "type": "string",
                  "description": "Dependency item ID.",
                  "minLength": 1
                }
              },
              "description": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Optional item description."
              }
            }
          }
        },
        "changedKeys": {
          "type": "array",
          "description": "Paths or IDs changed by the user.",
          "items": {
            "type": "string",
            "description": "Changed key path.",
            "minLength": 1
          }
        },
        "validation": {
          "type": "object",
          "description": "Validation results visible in UI.",
          "additionalProperties": false,
          "required": [
            "warnings",
            "errors"
          ],
          "properties": {
            "warnings": {
              "type": "array",
              "description": "Non-blocking warnings.",
              "items": {
                "type": "string",
                "description": "Warning text.",
                "minLength": 1
              }
            },
            "errors": {
              "type": "array",
              "description": "Errors to surface.",
              "items": {
                "type": "string",
                "description": "Error text.",
                "minLength": 1
              }
            }
          }
        },
        "exportSummary": {
          "type": "string",
          "description": "Human-readable summary of changes.",
          "minLength": 1
        }
      }
    }
  }
}
