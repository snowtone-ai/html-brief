{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://html-brief.dev/schemas/report.schema.json",
  "title": "html-brief Report schema",
  "description": "Schema for a Report archetype export.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "archetype",
    "createdAt",
    "userIntent",
    "state",
    "initialState"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Export protocol version.",
      "const": "1.0"
    },
    "archetype": {
      "type": "string",
      "description": "Archetype identifier.",
      "const": "report"
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 generation timestamp.",
      "format": "date-time"
    },
    "updatedAt": {
      "type": [
        "string",
        "null"
      ],
      "description": "ISO 8601 update timestamp or null.",
      "format": "date-time"
    },
    "userIntent": {
      "type": "string",
      "description": "Original or summarized user request.",
      "minLength": 1
    },
    "initialState": {
      "type": [
        "object",
        "null"
      ],
      "description": "Initial report state, usually null."
    },
    "state": {
      "type": "object",
      "description": "Report-specific state.",
      "additionalProperties": false,
      "required": [
        "title",
        "reportType",
        "summary",
        "metrics",
        "findings",
        "actions",
        "sources"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Report title.",
          "minLength": 1
        },
        "reportType": {
          "type": "string",
          "description": "Report type.",
          "enum": [
            "research",
            "incident",
            "status",
            "weekly",
            "explainer",
            "postmortem",
            "other"
          ]
        },
        "summary": {
          "type": "array",
          "description": "Executive conclusions.",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "type": "string",
            "description": "Conclusion bullet.",
            "minLength": 1
          }
        },
        "metrics": {
          "type": "array",
          "description": "Key metrics to show at top.",
          "maxItems": 4,
          "items": {
            "type": "object",
            "description": "Metric.",
            "additionalProperties": false,
            "required": [
              "label",
              "value",
              "meaning"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Metric label.",
                "minLength": 1
              },
              "value": {
                "type": "string",
                "description": "Displayed value.",
                "minLength": 1
              },
              "meaning": {
                "type": "string",
                "description": "Interpretation of the metric.",
                "minLength": 1
              },
              "tone": {
                "type": "string",
                "description": "Metric tone.",
                "enum": [
                  "success",
                  "warning",
                  "danger",
                  "info",
                  "neutral"
                ]
              }
            }
          }
        },
        "findings": {
          "type": "array",
          "description": "Key findings.",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "object",
            "description": "Finding.",
            "additionalProperties": false,
            "required": [
              "title",
              "evidenceType",
              "claim",
              "implication",
              "confidence"
            ],
            "properties": {
              "title": {
                "type": "string",
                "description": "Finding title.",
                "minLength": 1
              },
              "evidenceType": {
                "type": "string",
                "description": "Type of evidence.",
                "enum": [
                  "source-backed",
                  "user-provided",
                  "code-derived",
                  "inferred",
                  "assumption",
                  "uncertain"
                ]
              },
              "claim": {
                "type": "string",
                "description": "Specific claim.",
                "minLength": 1
              },
              "implication": {
                "type": "string",
                "description": "Why it matters.",
                "minLength": 1
              },
              "confidence": {
                "type": "string",
                "description": "Confidence in finding.",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              }
            }
          }
        },
        "timeline": {
          "type": "array",
          "description": "Optional timeline events.",
          "items": {
            "type": "object",
            "description": "Timeline event.",
            "additionalProperties": false,
            "required": [
              "label",
              "description"
            ],
            "properties": {
              "timestamp": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Date-time or date if known."
              },
              "label": {
                "type": "string",
                "description": "Event label.",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "description": "Event description.",
                "minLength": 1
              }
            }
          }
        },
        "actions": {
          "type": "array",
          "description": "Recommended action items.",
          "items": {
            "type": "object",
            "description": "Action item.",
            "additionalProperties": false,
            "required": [
              "action",
              "status"
            ],
            "properties": {
              "action": {
                "type": "string",
                "description": "Action description.",
                "minLength": 1
              },
              "owner": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Owner if known."
              },
              "status": {
                "type": "string",
                "description": "Action status.",
                "enum": [
                  "proposed",
                  "accepted",
                  "in_progress",
                  "blocked",
                  "done"
                ]
              },
              "rationale": {
                "type": "string",
                "description": "Why this action matters.",
                "minLength": 1
              }
            }
          }
        },
        "sources": {
          "type": "array",
          "description": "Sources or input materials.",
          "items": {
            "type": "object",
            "description": "Source.",
            "additionalProperties": false,
            "required": [
              "label",
              "type",
              "note"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Source label.",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "description": "Source type.",
                "enum": [
                  "user-provided",
                  "web",
                  "code",
                  "log",
                  "document",
                  "inference",
                  "other"
                ]
              },
              "url": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "URL if applicable.",
                "format": "uri"
              },
              "note": {
                "type": "string",
                "description": "How the source was used.",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
